# Condofy — variáveis de ambiente
# Copie para .env e preencha os valores reais

# Banco de dados (Railway provisiona automaticamente)
DATABASE_URL=postgresql://postgres:SENHA@localhost:5432/condofy

# Pluggy (credenciais da administradora padrão para desenvolvimento)
PLUGGY_CLIENT_ID=95a6b27b-3d9f-4bd7-9634-3d5ed1708699
PLUGGY_CLIENT_SECRET=0e5e33e2-81c9-45e5-bac6-badf5781238a

# URL do webhook (Railway gera automaticamente após deploy)
PLUGGY_WEBHOOK_URL=https://SEU-APP.railway.app/webhooks/pluggy

# Email (SendGrid — evitar spam, problema #13)
SENDGRID_API_KEY=SG.xxxxxxxx
EMAIL_FROM=noreply@condofy.com.br
EMAIL_FROM_NAME=Condofy

# Segurança
SECRET_KEY=troque-por-string-aleatoria-longa
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
